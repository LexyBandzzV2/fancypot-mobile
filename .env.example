# Copy to .env and fill in. All values are publishable (safe to ship in the app).

# Your existing Supabase project (shared with the web app so accounts are unified)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# RevenueCat public SDK keys (RevenueCat dashboard → Project → API keys)
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_xxxxxxxxxxxx
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_xxxxxxxxxxxx

# Skimlinks affiliate program ID (optional; when set, product links are wrapped for commission)
EXPO_PUBLIC_SKIMLINKS_ID=

# Sentry DSN (optional; error monitoring — crashes from real devices appear in your Sentry dashboard)
EXPO_PUBLIC_SENTRY_DSN=
